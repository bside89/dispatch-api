{
  "name": "order-flow-api",
  "version": "1.0.0",
  "description": "Order Flow API with NestJS, PostgreSQL, Redis and BullMQ",
  "author": "Bruno",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --selectProjects unit --watch",
    "test:cov": "jest --coverage",
    "test:int": "jest --selectProjects integration --runInBand",
    "test:e2e": "jest --selectProjects e2e --runInBand",
    "test:load": "docker run --rm -i --network=order-flow-api_order-flow-network grafana/k6 run -e BASE_URL=http://order-flow-api:3000 - <test/load-test.js",
    "test:load:local": "docker run --rm -i grafana/k6 run -e BASE_URL=http://host.docker.internal:3000 - <test/load-test.js",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:create": "npm run typeorm -- migration:create",
    "migration:generate": "npm run typeorm -- migration:generate -d src/config/typeorm.config.ts",
    "migration:show:": "npm run typeorm -- migration:show -d src/config/typeorm.config.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/config/typeorm.config.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/config/typeorm.config.ts",
    "debug": "chmod +x scripts/debug.sh && scripts/debug.sh",
    "stop": "chmod +x scripts/stop.sh && scripts/stop.sh",
    "reset": "chmod +x scripts/reset.sh && scripts/reset.sh",
    "reset-db": "chmod +x scripts/reset-db.sh && scripts/reset-db.sh",
    "fix-db": "chmod +x scripts/fix-db.sh && scripts/fix-db.sh",
    "create-db": "chmod +x scripts/create-db.sh && scripts/create-db.sh",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build --no-cache",
    "docker:logs": "docker compose logs -f",
    "docker:status": "docker compose ps"
  },
  "dependencies": {
    "@bull-board/api": "^6.20.6",
    "@bull-board/express": "^6.20.6",
    "@bull-board/nestjs": "^6.20.6",
    "@keyv/redis": "^5.1.6",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.8.0",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-store": "^3.0.1",
    "cacheable": "^2.3.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "keyv": "^5.6.0",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.11.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-loki": "^3.0.0",
    "pino-pretty": "^13.1.3",
    "redis": "^5.11.0",
    "redlock": "^5.0.0-beta.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.0",
    "typeorm": "^0.3.17",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@testcontainers/postgresql": "^11.13.0",
    "@testcontainers/redis": "^11.13.0",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.37",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.20.0",
    "@types/redlock": "^4.0.8",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^30.3.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "forceExit": true,
    "projects": [
      {
        "displayName": "unit",
        "testRegex": ".*\\.spec\\.ts$",
        "rootDir": "src",
        "transform": {
          "^.+\\.(t|j)s$": [
            "ts-jest",
            {
              "tsconfig": "tsconfig.spec.json"
            }
          ]
        },
        "moduleFileExtensions": [
          "js",
          "json",
          "ts"
        ],
        "moduleNameMapper": {
          "^@/(.*)$": "<rootDir>/$1"
        },
        "testEnvironment": "node"
      },
      {
        "displayName": "integration",
        "testRegex": ".*\\.int-spec\\.ts$",
        "rootDir": ".",
        "globalSetup": "<rootDir>/test/setup.ts",
        "globalTeardown": "<rootDir>/test/teardown.ts",
        "transform": {
          "^.+\\.(t|j)s$": [
            "ts-jest",
            {
              "tsconfig": "tsconfig.spec.json"
            }
          ]
        },
        "moduleFileExtensions": [
          "js",
          "json",
          "ts"
        ],
        "moduleNameMapper": {
          "^@/(.*)$": "<rootDir>/src/$1"
        },
        "testEnvironment": "node"
      },
      {
        "displayName": "e2e",
        "testRegex": ".*\\.e2e-spec\\.ts$",
        "rootDir": ".",
        "globalSetup": "<rootDir>/test/setup.ts",
        "globalTeardown": "<rootDir>/test/teardown.ts",
        "transform": {
          "^.+\\.(t|j)s$": [
            "ts-jest",
            {
              "tsconfig": "tsconfig.spec.json"
            }
          ]
        },
        "moduleFileExtensions": [
          "js",
          "json",
          "ts"
        ],
        "moduleNameMapper": {
          "^@/(.*)$": "<rootDir>/src/$1"
        },
        "testEnvironment": "node"
      }
    ]
  }
}
